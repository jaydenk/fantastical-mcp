# Optional: Override database path (auto-discovered by default)
# FANTASTICAL_DB_PATH=/path/to/Fantastical-8.fcdata

# Optional: Comma-separated calendar names to exclude
# FANTASTICAL_EXCLUDE_CALENDARS=Weather,Openings,RSVP Invitations,Proposals,Notifications

# Optional: Transport mode (stdio or sse)
# FANTASTICAL_MCP_TRANSPORT=stdio
# FANTASTICAL_MCP_HOST=127.0.0.1
# FANTASTICAL_MCP_PORT=8000
